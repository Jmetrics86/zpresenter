# ── zpresenter AI provider keys ──────────────────────────────────────────────
# Copy this file to .env and fill in the key for the provider you use.
# .env is gitignored — it will NOT be committed to version control.
#
# Only one key is needed. Add the others only if you switch providers.
#
# Anthropic (Claude Sonnet / Opus)
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o, o1)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini (Gemini Flash / Pro)
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
